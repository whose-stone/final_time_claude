# These defaults are hardcoded in src/lib/firebase.ts so the app works out of
# the box against the classroom Firebase project (claude-acu-game). You only
# need to set these env vars if you are pointing the app at a different
# Firebase project — env values take precedence over the defaults.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBfYXFazJ6UxnMD0-UiNtgR__eH0K4SxeI
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=claude-acu-game.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=claude-acu-game
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=claude-acu-game.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=48561989254
NEXT_PUBLIC_FIREBASE_APP_ID=1:48561989254:web:c6fbf2f1daef0daa77d307
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://claude-acu-game-default-rtdb.firebaseio.com

# Admin email list (comma separated). Anyone signed-in with an email in this list
# can access /admin. You can also flip the isAdmin flag on the user's node.
NEXT_PUBLIC_ADMIN_EMAILS=admin@acu.edu
