# Copy this to .env.local and fill in the remaining values from the
# Firebase Console (Project Settings > General > Your apps).
#
# Project ID is pre-filled based on the provided RTDB URL:
#   https://claude-acu-game-default-rtdb.firebaseio.com/
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=claude-acu-game.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=claude-acu-game
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=claude-acu-game.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://claude-acu-game-default-rtdb.firebaseio.com

# Admin email list (comma separated). Anyone signed-in with an email in this list
# can access /admin. You can also flip the isAdmin flag on the user's node.
NEXT_PUBLIC_ADMIN_EMAILS=admin@acu.edu
