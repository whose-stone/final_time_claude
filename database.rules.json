{
  "rules": {
    ".read": false,
    ".write": false,

    "players": {
      ".read": "auth != null && root.child('players').child(auth.uid).child('isAdmin').val() === true",

      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('players').child(auth.uid).child('isAdmin').val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('players').child(auth.uid).child('isAdmin').val() === true)",

        ".validate": "newData.hasChildren(['uid', 'email'])",

        "uid":             { ".validate": "newData.isString() && newData.val() === $uid" },
        "email":           { ".validate": "newData.isString()" },
        "displayName":     { ".validate": "newData.isString()" },
        "character":       { ".validate": "newData.isString() && (newData.val() === '' || newData.val() === 'boy' || newData.val() === 'girl')" },

        "isAdmin": {
          ".validate": "newData.isBoolean() && (newData.val() === false || !data.exists() && newData.val() === false || root.child('players').child(auth.uid).child('isAdmin').val() === true)"
        },

        "totalScore":              { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "lives":                   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99" },
        "currentLevel":            { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
        "checkpointLevel":         { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
        "checkpointQuestionIndex": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20" },
        "createdAt":               { ".validate": "newData.isNumber()" },
        "updatedAt":               { ".validate": "newData.isNumber()" },

        "levelResults": {
          "$idx": {
            ".validate": "newData.hasChildren(['level','score','correct','incorrect','gargoylesDefeated','timeSeconds','completedAt'])",
            "level":             { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
            "score":             { ".validate": "newData.isNumber()" },
            "correct":           { ".validate": "newData.isNumber()" },
            "incorrect":         { ".validate": "newData.isNumber()" },
            "gargoylesDefeated": { ".validate": "newData.isNumber()" },
            "timeSeconds":       { ".validate": "newData.isNumber()" },
            "completedAt":       { ".validate": "newData.isNumber()" },
            "$other":            { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    "questions": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('players').child(auth.uid).child('isAdmin').val() === true",
      "$qid": {
        ".validate": "newData.hasChildren(['id','level','type','prompt','answer','points'])",
        "id":       { ".validate": "newData.isString()" },
        "level":    { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
        "category": { ".validate": "newData.isString() && (newData.val() === 'bible' || newData.val() === 'test')" },
        "type":     { ".validate": "newData.isString() && newData.val() === 'multiple_choice'" },
        "prompt":   { ".validate": "newData.isString()" },
        "answer":   { ".validate": "newData.isString()" },
        "points":   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000" },
        "choices": {
          "$i": { ".validate": "newData.isString()" }
        },
        "$other": { ".validate": false }
      }
    },

    "config": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('players').child(auth.uid).child('isAdmin').val() === true"
    }
  }
}
